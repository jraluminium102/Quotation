# ===== Supabase (ดูได้ที่ Project Settings > API) =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# service role key — ใช้ฝั่ง server เท่านั้น ห้าม commit / ห้าม expose ขึ้น browser
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ===== Anthropic (สำหรับ AI Agents) =====
# ดู key ได้ที่: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง
